# Copy this file to .env and edit the values before running the agent locally.
AGENT_GO_API_KEY=replace-with-your-api-key
AGENT_GO_API_BASE=https://api.minimaxi.com
AGENT_GO_MODEL=MiniMax-M2.7
AGENT_GO_PROVIDER=anthropic

# Optional overrides
# AGENT_GO_CONFIG=
# AGENT_GO_WORKSPACE_DIR=./workspace
# AGENT_GO_MAX_STEPS=100
# AGENT_GO_SYSTEM_PROMPT_PATH=system_prompt.md
# AGENT_GO_ENABLE_FILE_TOOLS=true
# AGENT_GO_ENABLE_BASH=true
# AGENT_GO_ENABLE_NOTE=true
# AGENT_GO_ENABLE_MEMORY=true
# AGENT_GO_ENABLE_SKILLS=true
# AGENT_GO_SKILLS_DIR=./skills
# AGENT_GO_AUTO_SKILL_DIR=~/.agent-go/skills
